{
  "remote": {
    "host": "192.168.1.100",
    "port": 22,
    "username": "vaspuser",
    "auth_method": "password",
    "password_env": "REMOTE_SSH_PASSWORD",
    "ssh_key_path": null,
    "base_workdir": "/scratch/crewai-ase-runs"
  },
  "workflow": {
    "system_tag": "Fe2O3_bulk",
    "calculation_type": "relaxation",
    "task_goal": "Relax this structure and record converged energy and force summary."
  },
  "vasp": {
    "launch_command": "mpirun -np 16 vasp_std",
    "default_kpts": [6, 6, 6],
    "default_gamma": true,
    "default_incar": {
      "ENCUT": 520,
      "EDIFF": 1e-05,
      "EDIFFG": -0.02,
      "IBRION": 2,
      "NSW": 80,
      "ISIF": 3,
      "ISMEAR": 0,
      "SIGMA": 0.05,
      "PREC": "Accurate",
      "ALGO": "Normal"
    }
  },
  "agent": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "verbose": true
  },
  "external_db": {
    "url": "postgresql+psycopg://vasp_user:vasp_pass@localhost:5432/vasp_agent"
  }
}

